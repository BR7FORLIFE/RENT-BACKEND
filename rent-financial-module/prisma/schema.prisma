// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatusContract{
  DRAFT // borrador (fase de creación de contrato) 
  PENDING // pendiente (el documento esta a la espera de firma)
  EXECUTION // ejecucion (el contrato sigue vigente y activo)
  DEFEATED // vencido (el contrato llega a su finalizacion)
}

enum TypeStreet{
  STREET // calle
  CAREER // carrera
  AVENUE // avenida
  DIAGONAL // diagonal
  CROSS // transversal
}

// tipos de precios o pagos de servicio por medio de acuerdos
enum PriceTypeAgreement{
  CUSTOM_QUOTE // precio de servicio personalizado
  FIXED // precio fijo de servicio
  NEGOTIABLE // precio de servicio negociable
  PERCENTAGE // precio de servicio acordado por partes, cuotas, etc..
}

enum Currency{
  COP
  USD
}

//estados de pago de dicho servicio (modelo ya que el encargado de esta logica es el modulo de pagos)
enum PaymentStatus{
  PENDING // pendiente
  COMPLETE // completo
  FAILED // fallido
  OPEN // orden creado por el cliente pero no se ha completado la transaccion
  AUTHORIZE // pago autorizado por el banco pero aun no se ha destinado al negocio o al receptor
  PAID // servicio pagado y depositado a la cuenta del receptor
  EXPIRED // el tiempo limite para el pago ha expirado
  REIMBURSED // pago reembolsado por cualquier problema o por parte del banco
}

model TypeProperty{
  id String @id
  name String @unique
  description String?

  properties Property[]
}

model PropertyOccupationType{
  id String @id
  name String @unique
  description String?

  properties Property[]
}

model PropertyActorRole{
  id String @id
  name String @unique
  description String?

  propertyMemberRoles PropertyMemberRole[]
  services Service[]
}

model PublicServiceType{
  id String @id @default(uuid())
  name String @unique
  description String?

  publicServices PublicService[]
}

model ResourceImages{
  id String @id @default(uuid())
  propertyId String? @map("property_id")
  assetId String? @map("asset_id")
  width Int? 
  height Int?
  format String?
  url String
  secureUrl String? @map("secure_url")
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")

  property Property? @relation(fields: [propertyId], references: [id])
  contract Contract[]
}

model Direction{
  id String @id @default(uuid())
  latitute Decimal
  longitud Decimal
  department String
  city String
  neighborhood String
  typeStreet TypeStreet @map("type_street")
  numberStreet Int @map("number_street")
  complement String?
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")

  property Property?
}

model Property{
  id String @id @default(uuid())
  userId String @map("user_id")
  registerByUserId String @map("register_by_userId")
  propertyTypeId String @map("property_type_id")
  propertyOccupationTypeId String @map("property_occupation_type_id")
  directionId String @unique @map("direction_id")
  propertyName String @map("property_name")
  propertyDescription String @map("property_description")
  fmi String
  predialNumber String @map("predial_number")
  isPublished Boolean @map("is_published")
  
   // esto permite que los administradores validen la autenticidad del inmueble
  isActive Boolean @map("is_active") @default(false)
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")

  publicServices PublicService[]
  propertyMembers PropertyMember[]
  contracts Contract[]
  propertyServiceAssignments PropertyServiceAssignment[]
  direction Direction @relation(fields: [directionId], references: [id])
  typeProperty TypeProperty @relation(fields: [propertyTypeId], references: [id])
  propertyOccupationType PropertyOccupationType @relation(fields: [propertyOccupationTypeId], references: [id])
  resourceImages ResourceImages[]
}

model Contract{
  id String @id @default(uuid())
  propertyId String @map("property_id")
  landlordMemberId String @map("landlord_member_id")
  tenantMemberId String @map("tenant_member_id")
  monthlyRent Decimal @map("monthly_rent")
  depositAmount Decimal @map("deposit_amount")
  startDate DateTime @map("start_date")
  endDate DateTime @map("end_date")
  status StatusContract
  createByUserId String @map("create_by_user_id")
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")
  resourceImageId String? @map("resource_image_id")

  landlord PropertyMember @relation("LandlordContract", fields:[landlordMemberId],references:[id])
  tenant PropertyMember @relation("TenantContract", fields:[tenantMemberId], references:[id])
  property Property @relation(fields:[propertyId], references:[id])
  resourceImage ResourceImages? @relation(fields: [resourceImageId], references: [id])
}

model PropertyMember{
  id String @id @default(uuid())
  userId String @map("user_id")
  propertyId String @map("property_id")
  assignedBy String @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")
  updateAt DateTime @updatedAt @map("update_at")

  @@unique([userId, propertyId])

  property Property @relation(fields: [propertyId], references: [id])
  propertyMemberRole PropertyMemberRole[]
  propertyServiceAssignment PropertyServiceAssignment[]
  landlordContracts Contract[] @relation("LandlordContract")
  tenantContracts Contract[] @relation("TenantContract")
}

model PropertyMemberRole{
  id String @id @default(uuid())
  propertyMemberId String @map("property_member_id")
  propertyActorRoleId String @map("property_actor_role_id")

  @@unique([propertyActorRoleId, propertyMemberId])

  propertyMember PropertyMember @relation(fields: [propertyMemberId], references: [id])
  propertyActorRole PropertyActorRole @relation(fields: [propertyActorRoleId], references: [id])
}

model Service{
  id String @id @default(uuid())
  propertyActorRoleId String @map("property_actor_role_id")
  name String 
  description String

  propertyServiceAssignments PropertyServiceAssignment[]
  propertyActorRole PropertyActorRole @relation(fields: [propertyActorRoleId], references: [id])
}

model PropertyServiceAssignment{
  id String @id @default(uuid())
  propertyId String @map("property_id")
  propertyMemberId String @map("property_member_id")
  serviceId String @map("service_id")
  priceTypeAgreement PriceTypeAgreement @map("price_type_agreement")
  basePrice Decimal @map("base_price")
  currency Currency
  expirationDate DateTime @map("expiration_date")
  createAt DateTime @default(now()) @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")
  paymentStatus PaymentStatus @map("payment_status")

  propertyMember PropertyMember @relation(fields: [propertyMemberId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

model PublicService{
  id String @id @default(uuid())
  propertyId String @map("property_id")
  publicServiceTypeId String @map("public_service_type_id")
  accountNumber String @map("account_number")
  registerDate DateTime @default(now()) @map("register_date")
  updateAt DateTime @updatedAt @map("update_at")

  publicServiceType PublicServiceType @relation(fields:[publicServiceTypeId], references:[id])
  property Property @relation(fields:[propertyId], references:[id])
  @@unique([propertyId, publicServiceTypeId])
}